# Copy this file to `.env` and fill in the values.
# `.env` is gitignored, so each developer keeps their own local copy.

# Backend API base URL the app talks to (required).
# Note: when running a dev build on a physical phone, this must be reachable
# from the phone — not `localhost`. Use the deployed API or your machine's LAN
# IP (e.g. http://192.168.1.x:PORT).
EXPO_PUBLIC_API_URL=https://squad-up-ucf.net/api

# Optional — your own iOS bundle identifier for local dev builds.
# A bundle id can only be registered to one Apple team, so each developer
# building locally under their own (free) Apple account needs a unique one.
# Read by app.config.js; leave unset to use the default committed in app.json.
# IOS_BUNDLE_ID=com.yourname.squadup
